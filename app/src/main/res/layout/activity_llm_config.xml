<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <io.agents.pokeclaw.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16pt"
        android:paddingTop="8pt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Active Model Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Active Model"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16pt">

                    <TextView
                        android:layout_width="40pt"
                        android:layout_height="40pt"
                        android:background="@drawable/bg_avatar_ai"
                        android:gravity="center"
                        android:text="🦞"
                        android:textSize="22pt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12pt"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvActiveModelName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No model"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15pt"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvActiveModelMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2pt"
                            android:text="Tap to download a model"
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="12pt" />

                        <TextView
                            android:id="@+id/tvActiveModelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4pt"
                            android:text="● Not configured"
                            android:textColor="@color/colorSuccessPrimary"
                            android:textSize="12pt" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Available Models -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Available Models"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutModelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Storage section hidden — not useful for end users -->
            <TextView
                android:id="@+id/tvStorageInfo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <ProgressBar
                android:id="@+id/progressStorage"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvStorageDetail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Cloud LLM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Cloud LLM"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24pt"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16pt">

                    <!-- Provider Tabs -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12pt">

                        <LinearLayout
                            android:id="@+id/layoutProviderTabs"
                            android:layout_width="wrap_content"
                            android:layout_height="40pt"
                            android:background="@drawable/bg_edit_text"
                            android:orientation="horizontal"
                            android:padding="3pt" />

                    </HorizontalScrollView>

                    <!-- Model List (programmatic) -->
                    <LinearLayout
                        android:id="@+id/layoutCloudModels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- API Key -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API Key"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12pt"
                        android:layout_marginTop="12pt"
                        android:layout_marginBottom="4pt" />

                    <EditText
                        android:id="@+id/etApiKey"
                        android:layout_width="match_parent"
                        android:layout_height="44pt"
                        android:background="@drawable/bg_edit_text"
                        android:hint="sk-..."
                        android:inputType="textPassword"
                        android:paddingHorizontal="12pt"
                        android:textColor="@color/colorTextPrimary"
                        android:textColorHint="@color/colorTextTertiary"
                        android:textSize="13pt" />

                    <!-- Base URL (Custom only) -->
                    <LinearLayout
                        android:id="@+id/layoutBaseUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Base URL"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12pt"
                            android:layout_marginTop="10pt"
                            android:layout_marginBottom="4pt" />

                        <EditText
                            android:id="@+id/etBaseUrl"
                            android:layout_width="match_parent"
                            android:layout_height="44pt"
                            android:background="@drawable/bg_edit_text"
                            android:hint="https://api.openrouter.ai/v1"
                            android:inputType="textUri"
                            android:paddingHorizontal="12pt"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextTertiary"
                            android:textSize="13pt" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Model Name"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12pt"
                            android:layout_marginTop="10pt"
                            android:layout_marginBottom="4pt" />

                        <EditText
                            android:id="@+id/etModelName"
                            android:layout_width="match_parent"
                            android:layout_height="44pt"
                            android:background="@drawable/bg_edit_text"
                            android:hint="google/gemini-2.5-flash"
                            android:inputType="text"
                            android:paddingHorizontal="12pt"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextTertiary"
                            android:textSize="13pt" />

                    </LinearLayout>

                    <!-- Connection Status -->
                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8pt"
                        android:textSize="12pt"
                        android:visibility="gone" />

                    <!-- Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14pt"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnTestConnection"
                            android:layout_width="0dp"
                            android:layout_height="44pt"
                            android:layout_weight="1"
                            android:layout_marginEnd="6pt"
                            android:background="@drawable/bg_edit_text"
                            android:gravity="center"
                            android:text="Test"
                            android:textColor="@color/colorBrandPrimary"
                            android:textSize="13pt" />

                        <io.agents.pokeclaw.widget.KButton
                            android:id="@+id/btnSaveCloud"
                            android:layout_width="0dp"
                            android:layout_height="44pt"
                            android:layout_weight="2"
                            android:text="Save &amp; Activate" />

                    </LinearLayout>

                    <!-- Compatible endpoints hint (Custom only) -->
                    <TextView
                        android:id="@+id/tvCustomHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8pt"
                        android:text="Compatible with: OpenRouter, Groq, Together AI, Ollama, any OpenAI-compatible endpoint"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="10pt"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
