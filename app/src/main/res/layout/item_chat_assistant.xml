<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingStart="12pt"
    android:paddingEnd="56pt"
    android:paddingVertical="3pt">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="28pt"
        android:layout_height="28pt"
        android:background="@drawable/bg_avatar_ai"
        android:gravity="center"
        android:text="🦞"
        android:textSize="15pt"
        android:layout_marginEnd="8pt"
        android:layout_gravity="bottom" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_assistant"
        android:paddingHorizontal="14pt"
        android:paddingVertical="9pt"
        android:textColor="@color/colorTextPrimary"
        android:textSize="15pt"
        android:lineSpacingExtra="3pt" />
</LinearLayout>
